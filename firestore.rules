rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Visitor counters
    match /visitors/counters {
      allow read: if true;
      // Allow updates to the counters document, check that it exists
      allow write: if true;
    }
    
    // Active sessions presence
    match /active_sessions/{sessionId} {
      allow read, write: if true;
    }
  }
}
